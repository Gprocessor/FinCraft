# FinCraft / Fineract (PostgreSQL) - PRODUCTION (multi-tenant)
# Everything (infra + the FinCraft frontend) lives in this one repo now —
# clone it, copy this file to .env, edit, and run ./setup-vm.sh.
POSTGRES_PASSWORD=change-me-postgres
FINERACT_DB_PASSWORD=change-me-app
FINERACT_IMAGE=apache/fineract:latest

# Fineract's own built-in tenant is normally named 'default'. This overrides
# that at first boot (via Fineract's FINERACT_DEFAULT_TENANTDB_IDENTIFIER env
# var — see docker-compose.yml) so your first tenant is literally 'fincraft'.
# Only takes effect on a FRESH deploy (the tenants DB doesn't exist yet).
DEFAULT_TENANT_IDENTIFIER=fincraft
# The actual Postgres database/schema for that first tenant (independent of
# the identifier above — Fineract keeps these as two separate settings).
# Also only takes effect on a FRESH deploy (init-db only runs once, against
# an empty data volume).
DEFAULT_TENANT_DB_NAME=fineract_fincraft

# Auto-update: this deploy checkout pulls its own git remote periodically
# (see setup-vm.sh step 9) to pick up changes to the frontend, infra scripts,
# or docker-compose.yml. Set true + a deploy key only if you cloned this repo
# over SSH from a private remote and want unattended pulls to keep working.
REPO_PRIVATE=false
DEPLOY_KEY=/home/ubuntu/.ssh/fincraft_deploy

# First deployment: ONE domain only (the fincraft tenant). Add more domains here
# later, one at a time, after running ./add-tenant.sh for each new tenant.
DOMAINS="fincraft.duckdns.org"
# Explicit domain->tenant map used to generate the frontend's TENANT_MAP.
# Format: space-separated "domain:tenantIdentifier" pairs. add-tenant.sh
# appends to this automatically when you add a tenant — you shouldn't need
# to hand-edit it. The first entry should match DEFAULT_TENANT_IDENTIFIER
# above.
TENANT_DOMAINS="fincraft.duckdns.org:fincraft"
LETSENCRYPT_EMAIL=sfincraft@gmail.com
# Runs after each nightly DB dump, once per database, with {} replaced by
# that dump's file path — e.g. to upload to Google Drive, run
# ./setup-gdrive-backup.sh once (one-time Google sign-in, then fully
# unattended forever) and it'll give you the exact line to put here:
#   BACKUP_UPLOAD_CMD='rclone copy {} gdrive:fincraft-backups/'
BACKUP_UPLOAD_CMD=
ALERT_CMD=
PUBLIC_HOST=

# Outbound email: configured automatically via Fineract's own built-in Gmail
# SMTP relay (GmailBackedPlatformEmailService) — for the first tenant during
# ./setup-vm.sh, and for every tenant added afterward via ./add-tenant.sh.
# Requires a Gmail *App Password*, not your normal Gmail password:
# Gmail Account -> Security -> 2-Step Verification (must be ON) -> App passwords.
# Google displays it as 4 groups of 4 chars with spaces, e.g. "abcd efgh ijkl
# mnop" — QUOTE IT here or the spaces will break .env parsing:
#   GMAIL_APP_PASSWORD="abcd efgh ijkl mnop"
# (configure-email.sh also strips spaces defensively either way.)
# Leave blank to skip email setup (you can run ./configure-email.sh anytime later).
GMAIL_ADDRESS=sfincraft@gmail.com
GMAIL_APP_PASSWORD="xsub hzad gmft wghi"
GMAIL_FROM_NAME=FinCraft
# Only needed if you've already rotated the admin password for the tenant
# configure-email.sh is targeting (fresh deploys use Fineract's own default
# mifos/password automatically).
FINERACT_ADMIN_USERNAME=mifos
FINERACT_ADMIN_PASSWORD=password

# Auto-update deploy reports: the auto-update watcher (setup-vm.sh step 9)
# emails a report — commits pulled + result — over the same Gmail SMTP creds
# above, whenever a pull actually deploys something, plus a failure report if
# the pull/deploy fails. Silent (no email) on every "no changes" check.
# Also used by daily-report.sh (cron, 07:00 daily) for a once-a-day digest of
# host logs (autoupdate/backup/monitor) plus each container's last 24h.
# Defaults to GMAIL_ADDRESS (sends to yourself) — set this only if you want
# reports to go somewhere else instead.
DEPLOY_NOTIFY_EMAIL=sfincraft@gmail.com

# Keycloak — OAuth2/OIDC identity provider (in progress, not yet flipped on
# for real Fineract login — see deploy/KEYCLOAK-SETUP.md for where things
# stand). Bound to 127.0.0.1 only right now, reached via SSH tunnel.
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=
# Separate from POSTGRES_PASSWORD/FINERACT_DB_PASSWORD — Keycloak gets its
# own role + database (see init-db/02-init-keycloak.sh) in the same shared
# Postgres container, rather than a second Postgres instance.
KEYCLOAK_DB_PASSWORD=
