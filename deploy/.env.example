# FinCraft / Fineract (PostgreSQL) - PRODUCTION (multi-tenant)
# Everything (infra + the FinCraft frontend) lives in this one repo now —
# clone it, copy this file to .env, edit, and run ./setup-vm.sh.
POSTGRES_PASSWORD=change-me-postgres
FINERACT_DB_PASSWORD=change-me-app
FINERACT_IMAGE=apache/fineract:latest

# Fineract's own built-in tenant is normally named 'default'. This overrides
# that at first boot (via Fineract's FINERACT_DEFAULT_TENANTDB_IDENTIFIER env
# var — see docker-compose.yml) so your first tenant is literally 'fincraft'.
# Only takes effect on a FRESH deploy (the tenants DB doesn't exist yet).
DEFAULT_TENANT_IDENTIFIER=fincraft
# The actual Postgres database/schema for that first tenant (independent of
# the identifier above — Fineract keeps these as two separate settings).
# Also only takes effect on a FRESH deploy (init-db only runs once, against
# an empty data volume).
DEFAULT_TENANT_DB_NAME=fineract_fincraft

# Auto-update: this deploy checkout pulls its own git remote periodically
# (see setup-vm.sh step 9) to pick up changes to the frontend, infra scripts,
# or docker-compose.yml. Set true + a deploy key only if you cloned this repo
# over SSH from a private remote and want unattended pulls to keep working.
REPO_PRIVATE=false
DEPLOY_KEY=/home/ubuntu/.ssh/fincraft_deploy

# First deployment: ONE domain only (the fincraft tenant). Add more domains here
# later, one at a time, after running ./add-tenant.sh for each new tenant.
DOMAINS="fincraft.duckdns.org"
# Explicit domain->tenant map used to generate the frontend's TENANT_MAP.
# Format: space-separated "domain:tenantIdentifier" pairs. add-tenant.sh
# appends to this automatically when you add a tenant — you shouldn't need
# to hand-edit it. The first entry should match DEFAULT_TENANT_IDENTIFIER
# above.
TENANT_DOMAINS="fincraft.duckdns.org:fincraft"
LETSENCRYPT_EMAIL=you@example.com
BACKUP_UPLOAD_CMD=
ALERT_CMD=
PUBLIC_HOST=
